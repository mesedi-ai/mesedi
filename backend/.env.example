# Mesedi backend — example environment variables
# Copy to `.env` and fill in real values. `.env` is gitignored.

# HTTP server
MESEDI_PORT=8080
MESEDI_LOG_LEVEL=info

# Database — SQLite for local dev, Postgres for production
# Default (SQLite, zero-deps): file:./mesedi-dev.db?_pragma=journal_mode(WAL)&_pragma=foreign_keys(on)
# Production target (Postgres / Neon): postgres://user:pass@host.neon.tech/mesedi?sslmode=require
# The Store interface in internal/store/ will route to the right backend
# based on the URL scheme. SQLite implementation lives in sqlite.go;
# Postgres comes online in a future slice.
MESEDI_DB_URL=file:./mesedi-dev.db?_pragma=journal_mode(WAL)&_pragma=foreign_keys(on)

# Embedding API (for drift detection — Phase 7)
# Stub until needed. Wire OpenAI's text-embedding-3-small or equivalent.
OPENAI_API_KEY=

# Anthropic API (for LLM-judge validators — Phase 6+)
ANTHROPIC_API_KEY=

# Transactional email (#127). Resend HTTP API. Leave empty to disable
# (NoopMailer swallows sends, suitable for local dev and CI). When set,
# the welcome email fires on every successful POST /signup.
RESEND_API_KEY=
# From address shown in the customer's inbox. Resend's "onboarding@resend.dev"
# sandbox works for local testing without domain verification. For
# production use a verified domain.
MESEDI_MAIL_FROM=Mesedi <onboarding@resend.dev>

# 5xx alert webhook (#130). When set, the request-log middleware
# POSTs an alert payload to this URL on every 5xx response so the
# operator gets paged before customers notice. Auto-detects Slack and
# Discord webhook URL shapes; falls back to generic JSON. Leave empty
# to disable alerting.
MESEDI_ALERT_WEBHOOK_URL=
